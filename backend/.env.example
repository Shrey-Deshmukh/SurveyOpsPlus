# Database
DB_NAME=surveyopsplus
DB_USER=surveyopsplus_user
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5432
DB_MIN_CONN=1
DB_MAX_CONN=10

# Encryption (generate with: openssl rand -hex 32)
DB_ENCRYPTION_KEY=your_db_encryption_key

# Dropbox (from https://www.dropbox.com/developers/apps)
DROPBOX_APP_KEY=your_dropbox_app_key
DROPBOX_APP_SECRET=your_dropbox_app_secret
DROPBOX_REDIRECT_URI=http://localhost:8000/api/v1/dropbox/callback
DROPBOX_TEST_REFRESH_TOKEN=your_dropbox_refresh_token

# Google Gemini (from https://aistudio.google.com/)
GOOGLE_API_KEY=your_google_api_key